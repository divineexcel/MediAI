# ─────────────────────────────────────────────
# MediSave Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database
DB_DRIVER=sqlite
DB_PATH=./data/medisave.db

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_ACCESS_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=./config/firebase-service-account.json

# Medical AI API
AI_API_BASE_URL=https://your-medical-ai-api.com
AI_API_KEY=your-ai-api-key
AI_API_TIMEOUT_SECONDS=30

# SMS Gateway (Africa's Talking)
SMS_GATEWAY_URL=https://api.africastalking.com/version1/messaging
SMS_API_KEY=your-africastalking-api-key
SMS_USERNAME=sandbox
SMS_SENDER_ID=MediSave

# USSD
USSD_SERVICE_CODE=*384*123#

# Email (future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@medisave.ng
SMTP_PASSWORD=your-smtp-password

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Logging
LOG_LEVEL=info
LOG_OUTPUT=stdout
